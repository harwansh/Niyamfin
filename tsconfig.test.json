{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "outDir": ".test-build",
    "rootDir": ".",
    "noEmit": false,
    "declaration": false,
    "sourceMap": false,
    "incremental": false,
    "types": ["node"]
  },
  "include": ["src/lib/**/*.ts", "tests/**/*.ts"]
}
